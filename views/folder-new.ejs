<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/reset.css" />
    <link rel="stylesheet" href="/css/navbar.css" />
    <link rel="stylesheet" href="/css/folder-new.css" />
  </head>
  <body>
    <%- include("./partials/navbar.ejs") %>
    <main>
      <div class="wrapper">
        <% const parentIdParam = locals.parentId ? locals.parentId + '/' : '' %>
        <%- include("./partials/form-errors.ejs") %>

        <form action="/folder/<%= parentIdParam %>new" method="POST">
          <h2 class="form-heading">New Folder</h2>

          <div class="form-field">
            <label for="folder_name">Name:</label>
            <input
              type="text"
              id="folder_name"
              name="folder_name"
              minlength="1"
              maxlength="50"
              value="<%= locals.prevName %>"
              required
            />
          </div>

          <div class="btn-container">
            <button type="submit" class="submit-btn">Create</button>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>
