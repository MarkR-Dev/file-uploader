<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/reset.css" />
    <link rel="stylesheet" href="/css/navbar.css" />
    <link rel="stylesheet" href="/css/sign-up.css" />
  </head>
  <body>
    <%- include("./partials/navbar.ejs") %>

    <main>
      <div class="wrapper">
        <form action="/sign-up" method="POST">
          <h2 class="form-heading">Sign Up</h2>

          <div class="form-field">
            <label for="username_sign_up">Username:</label>
            <input
              type="text"
              name="username_sign_up"
              id="username_sign_up"
              minlength="5"
              maxlength="20"
              required
            />
          </div>

          <div class="form-field">
            <label for="email_sign_up">Email:</label>
            <input
              type="email"
              name="email_sign_up"
              id="email_sign_up"
              minlength="5"
              maxlength="50"
              required
            />
          </div>

          <div class="form-field">
            <label for="password_sign_up">Password:</label>
            <input
              type="password"
              name="password_sign_up"
              id="password_sign_up"
              minlength="8"
              maxlength="20"
              required
            />
          </div>

          <div class="form-field">
            <label for="confirm_password_sign_up">Confirm Password:</label>
            <input
              type="password"
              name="confirm_password_sign_up"
              id="confirm_password_sign_up"
              minlength="8"
              maxlength="20"
              required
            />
          </div>

          <div class="btn-container">
            <button class="submit-btn" type="submit">Submit</button>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>
